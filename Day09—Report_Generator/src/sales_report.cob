IDENTIFICATION DIVISION.
PROGRAM-ID. SALES-REPORT.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.

FILE-CONTROL.
    SELECT SALES-FILE ASSIGN TO "sales.dat"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT REPORT-FILE ASSIGN TO "report.txt"
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.

FILE SECTION.

FD SALES-FILE.
01 SALES-RECORD.
   05 PRODUCT-ID PIC 9(3).
   05 SALE-VALUE PIC 9(5).

FD REPORT-FILE.
01 REPORT-LINE PIC X(50).

WORKING-STORAGE SECTION.

01 TOTAL-SALES PIC 9(7) VALUE 0.
01 EOF-FLAG PIC X VALUE "N".
01 SALES-COUNT PIC 9(5) VALUE 0.
PROCEDURE DIVISION.

MAIN-PROGRAM.

    OPEN INPUT SALES-FILE
    OPEN OUTPUT REPORT-FILE

    PERFORM UNTIL EOF-FLAG = "Y"
        READ SALES-FILE
            AT END
                MOVE "Y" TO EOF-FLAG
            NOT AT END
                PERFORM PROCESS-SALE
        END-READ
    END-PERFORM

    PERFORM WRITE-TOTAL

    CLOSE SALES-FILE
    CLOSE REPORT-FILE

    STOP RUN.

PROCESS-SALE.
    ADD SALE-VALUE TO TOTAL-SALES.
    ADD 1 TO SALES-COUNT.

WRITE-TOTAL.
    MOVE "TOTAL SALES: " TO REPORT-LINE
    WRITE REPORT-LINE

    MOVE TOTAL-SALES TO REPORT-LINE
    WRITE REPORT-LINE.
DISPLAY "Report generated successfully".
DISPLAY "Records processed: " SALES-COUNT.
DISPLAY "Total sales value: " TOTAL-SALES.
